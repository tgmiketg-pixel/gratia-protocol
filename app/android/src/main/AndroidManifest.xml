<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location: required for Proof of Life GPS fix attestation -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Wi-Fi: required for network peer discovery and PoL Wi-Fi attestation -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Bluetooth: required for peer discovery, mesh networking, and PoL BT attestation -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <!-- Android 12+ Bluetooth permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Camera: required for QR code scanning in wallet send flow -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- NFC: required for tap-to-transact feature -->
    <uses-permission android:name="android.permission.NFC" />

    <!-- Foreground service: required for PoL background collection and mining -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires declaring foreground service types -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Battery optimization exemption: allows requesting that Samsung, Xiaomi, Huawei
         and other aggressive OEMs don't kill the ProofOfLifeService in the background.
         Without this, PoL sensor collection silently stops on many devices. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Boot completed: restart PoL service after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Wake lock: keep CPU alive during mining while plugged in -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Internet: required for libp2p QUIC transport (peer-to-peer networking) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state: check connectivity for consensus participation -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- NFC is optional — Wi-Fi-only phones are first-class citizens -->
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <!-- Bluetooth is optional — Wi-Fi alone satisfies the connectivity requirement -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <application
        android:name=".GratiaApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gratia"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Gratia">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Proof of Life background sensor collection service.
             Runs as a foreground service so Android doesn't kill it during
             normal phone usage throughout the day. -->
        <service
            android:name=".service.ProofOfLifeService"
            android:exported="false"
            android:foregroundServiceType="location|connectedDevice" />

        <!-- Mining service. Active only when phone is plugged in and battery >= 80%.
             Uses a wake lock to keep the CPU alive for consensus work. -->
        <service
            android:name=".service.MiningService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- NFC Host Card Emulation service for tap-to-transact.
             WHY exported="true": The Android NFC system service must be able to
             route incoming APDU commands from external NFC readers to this service.
             The BIND_NFC_SERVICE permission ensures only the system can bind to it. -->
        <service
            android:name=".service.NfcTransactService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/nfc_aid_list" />
        </service>

        <!-- Restart PoL service after device reboot.
             WHY exported="true": Boot receivers must be exported to receive
             the system BOOT_COMPLETED broadcast.
             WHY directBootAware="true": Fires before user unlock on Android 7.0+,
             so PoL data collection starts immediately — not hours later when
             the user first unlocks. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- WHY: HTC, Samsung, and some other OEMs send QUICKBOOT_POWERON
                     instead of BOOT_COMPLETED on fast-boot/hibernation resume. -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
