<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for the Gratia home screen widget.
    Two lines: balance (bold, 18sp) and mining status (12sp, gray).
    Tapping anywhere opens the main app via widget_root click handler.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/widget_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.00 GRAT"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Not Mining"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray" />

</LinearLayout>
