<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- WHY: Minimal XML theme for the Activity window before Compose takes over.
         Status bar set to Deep Navy for brand consistency from the moment the app
         launches. Navigation bar transparent so Compose handles it. -->
    <style name="Theme.Gratia" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/gratia_deep_navy</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/gratia_warm_white</item>
    </style>
</resources>
