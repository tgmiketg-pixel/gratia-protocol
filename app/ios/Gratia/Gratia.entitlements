<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ================================================================== -->
	<!-- Gratia App Entitlements                                            -->
	<!-- WHY: Each entitlement enables a specific iOS capability required   -->
	<!-- for the Gratia protocol to function.                               -->
	<!-- ================================================================== -->

	<!-- NFC Tag Reading: Required for tap-to-transact -->
	<key>com.apple.developer.nfc.readersession.formats</key>
	<array>
		<string>NDEF</string>
		<string>TAG</string>
	</array>

	<!-- Wi-Fi Information: Required for Wi-Fi BSSID access (PoL network parameter) -->
	<key>com.apple.developer.networking.wifi-info</key>
	<true/>

	<!-- Background Modes: Already declared in Info.plist UIBackgroundModes -->
	<!-- No additional entitlement key needed for background modes -->

	<!-- Keychain Access Groups: For secure key storage -->
	<!-- WHY: The wallet's Ed25519 private key is stored in the iOS Keychain
	     with Secure Enclave protection. This entitlement scopes access to
	     the Gratia app only. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)io.gratia.app</string>
	</array>
</dict>
</plist>
